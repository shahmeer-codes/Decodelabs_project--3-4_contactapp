<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Contact</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
  <div class="hero">
    <div class="form-container">
      <div class="card">
        <header class="header" style="margin-bottom: 1.5rem; align-items: flex-start; flex-direction: column; gap: 0.5rem;">
          <h1 class="page-title" style="font-size: 1.5rem;">Edit Contact</h1>
          <p class="page-subtitle">Update the contact's information below.</p>
        </header>

        <form method="post" action="/edit/<%= contact._id %>">
          <div class="form-group">
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" class="form-input" value="<%= contact.name %>" required>
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-input" value="<%= contact.email %>" required>
          </div>
          <div class="form-group">
            <label for="phone" class="form-label">Phone</label>
            <input type="tel" id="phone" name="phone" class="form-input" value="<%= contact.phone %>" required>
          </div>
          
          <div style="display: flex; gap: 1rem; margin-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="flex: 1;">Update Contact</button>
            <a href="/" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>